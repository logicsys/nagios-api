def validate_nagios_command(command_str):
    '''Validate a raw Nagios command string against the allowlist.
    Returns (True, None) on success or (False, error_message) on failure.
    '''
    if not command_str or not isinstance(command_str, str):
        return False, 'Missing or invalid command string.'
    parts = command_str.split(';')
    verb = parts[0].strip()
    if verb not in ALLOWED_NAGIOS_COMMANDS:
        return False, 'Command is not allowed.'
    for part in parts:
        if '\n' in part or '\r' in part:
            return False, 'Command arguments must not contain newlines.'
    return True, None


def safe_cfg_path(cfg_directory, file_name):
    '''Validate and return a safe file path within cfg_directory.
    Raises ValueError if the path is unsafe.
    '''
    if not file_name or not isinstance(file_name, str):
        raise ValueError('No file name specified.')
    safe_name = os.path.basename(file_name)
    if not safe_name:
        raise ValueError('Invalid file name.')
    if not CFG_FILENAME_RE.match(safe_name):
        raise ValueError(
            'Invalid file name. Must contain only alphanumeric characters, '
            'hyphens, underscores, dots, and must end with .cfg')
    full_path = os.path.realpath(os.path.join(cfg_directory, safe_name))
    real_dir = os.path.realpath(cfg_directory)
    if not full_path.startswith(real_dir + os.sep):
        raise ValueError('File path escapes config directory.')
    return full_path


def http_send_raw_command(req, objid, reqobj):
    command = reqobj.get('command')
    if not command:
        return json_error(req, "Missing command to send to nagios")

    valid, err = validate_nagios_command(command)
    if not valid:
        return json_error(req, err)

    if not send_nagios_command(command):
        return json_error(req, "Nagios command failed")

    return json_response(req, "Nagios command succeeded")


def http_update_host(req, objid, reqobj):
    _mkdir_recursive(CFG_DIRECTORY)

    file_name = reqobj.get('file_name')
    text = reqobj.get('text')

    if not text:
        return json_error(req, 'No text specified.')

    try:
        file_path = safe_cfg_path(CFG_DIRECTORY, file_name)
    except ValueError as e:
        return json_error(req, str(e))

    try:
        if os.path.isfile(file_path):
            os.remove(file_path)

        with open(file_path, 'w') as f:
            f.write(text)

        log.info('Config file saved: %s', os.path.basename(file_path))

        uid = pwd.getpwnam("nagios").pw_uid
        gid = grp.getgrnam("nagios").gr_gid

        if uid and gid:
            os.chown(file_path, uid, gid)

        return json_response(req, {'message': 'Update file ' + os.path.basename(file_path)})
    except Exception as e:
        log.error('Unable to write file %s: %s', os.path.basename(file_path), e)
        return json_error(req, 'Unable to write file.')


