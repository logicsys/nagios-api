def http_schedule_check(req, objid, reqobj):
    '''Schedules a check for a host or service.

    Requires the host parameter to be sent, and also accepts a service
    parameter. If you wish to schedule checks for all services on a host,
    you can use the all_services parameter.

    Scheduling a non-forced check, does not mean the check will occur.
    If active checks have been disabled either on a program-wide or
    service level, or the services are already scheduled to be checked
    sooner than your requested time, the check will not be performed,
    unless forced mode is enabled (see below).

    The following optional parameters are also available:

    check_time (int): The time at which to schedule the check, in time_t
    (UNIX timestamp) format. Defaults to current time.

    forced (0/1): If set to 1, the scheduled check will be marked as
    forced, meaning it will be performed, even if there has been other
    checks run on the host or service in the mean time. Defaults to 0
    (off).

    all_services (0/1): If set to 1, all services for the specified
    host will be checked. Enabling this option, will cause the service
    parameter to be ignored, if supplied. Defaults to 0 (off).

    '''
    from time import time
    if not CMD_ENABLED:
        return json_error(req, 'External commands not enabled on nagios-api.')

    host = reqobj.get('host')
    service = reqobj.get('service')
    check_time = reqobj.get('check_time', time())
    forced = reqobj.get('forced', 0)
    all_services = reqobj.get('all_services', 0)

    nagios = get_nagios()
    obj = nagios.host_or_service(host, service)
    if obj is None:
        return json_error(req, 'Failed to find host or service to update.')

    try:
        check_time = int(check_time)
        forced = int(forced)
        all_services = int(all_services)
    except ValueError:
        return json_error(req, 'Invalid value provided for check_time, all_services or forced')

    if obj.service is not None:
        if forced:
            if not send_nagios_command('SCHEDULE_FORCED_SVC_CHECK', host, service, check_time):
                return json_error(req, 'Failed sending command to Nagios.')
        else:
            if not send_nagios_command('SCHEDULE_SVC_CHECK', host, service, check_time):
                return json_error(req, 'Failed sending command to Nagios.')
    else:
        if forced:
            if not send_nagios_command('SCHEDULE_FORCED_HOST_CHECK', host, check_time):
                return json_error(req, 'Failed sending command to Nagios.')
        else:
            if not send_nagios_command('SCHEDULE_HOST_CHECK', host, check_time):
                return json_error(req, 'Failed sending command to Nagios.')

        if all_services:
            if forced:
                if not send_nagios_command('SCHEDULE_FORCED_HOST_SVC_CHECKS', host, check_time):
                    return json_error(req, 'Failed sending command to Nagios.')
            else:
                if not send_nagios_command('SCHEDULE_HOST_SVC_CHECKS', host, check_time):
                    return json_error(req, 'Failed sending command to Nagios.')

    return json_response(req, 'submitted')


def http_handler(req):
    '''Handle an incoming HTTP request.

    '''
    # All requests should follow this very simple format.
    url = req.script_root + req.path
    url = unquote(url)
    res = URL_REGEX.match(url)
    if res is None:
        return json_error(req, 'Invalid request URI')
    verb, objid = res.group(1), res.group(2)
    try:
        objid = int(objid)
    except ValueError:
        pass
    except TypeError:
        objid = None

    # If it's a POST, try to extract a JSON object from the body.
    reqobj = None
    if req.method == 'POST':
        try:
            reqobj = req.json
        except BadRequest:
            return json_error(req, 'Invalid JSON body')

        if reqobj is None:
            return json_error(
                req, 'No JSON detected, did you set '
                'the Content-Type to application/json?')

    # Dispatch table goes here
    dispatch = {
        'GET': {
            'log': http_log,
            'state': http_state,
            'objects': http_objects,
            'host': http_host,
            'service': http_service,
            'problems': http_problems,
            'status': http_status,
            'service': http_service,
            'restart_nagios': http_restart_nagios_get_rejected
        },
        'POST': {
            'restart_nagios': http_restart_nagios,
            'cancel_downtime': http_cancel_downtime,
            'schedule_downtime': http_schedule_downtime,
            'schedule_hostgroup_downtime': http_schedule_hostgroup_downtime,
            'disable_notifications': http_disable_notifications,
            'enable_notifications': http_enable_notifications,
            'disable_checks': http_disable_checks,
            'enable_checks': http_enable_checks,
            'submit_result': http_submit_result,
            'acknowledge_problem': http_acknowledge_problem,
            'remove_acknowledgement': http_remove_acknowledgement,
            'add_comment': http_add_comment,
            'delete_comment': http_delete_comment,
            'schedule_check': http_schedule_check,
            'update_host': http_update_host,
            'raw_command': http_send_raw_command
        }
    }

    if req.method not in dispatch:
        return json_error(req, 'Method not supported.')
    if verb not in dispatch[req.method]:
        return json_error(req, 'Unknown endpoint.')
    return dispatch[req.method][verb](req, objid, reqobj)


def send_nagios_command(*args):
    '''Send a simple command to our local Nagios server.

    '''
    if not CMD_ENABLED:
        log.error('Command is disabled')
        return False  # May not be enabled.
    if len(args) < 1:
        log.error('Not enough parameters to send command')
        return False
    # Reject arguments containing newlines or semicolons to prevent
    # command injection.  Nagios commands are semicolon-delimited, so a
    # semicolon inside an argument (e.g. comment or author) would be
    # interpreted as an extra field by Nagios.
    # The first arg is the command verb (or a pre-validated raw command
    # string that legitimately contains semicolons), so semicolon checks
    # apply only to subsequent arguments.
    MAX_ARG_LENGTH = 8192
    for i, a in enumerate(args):
        s = str(a)
        if len(s) > MAX_ARG_LENGTH:
            log.error('Rejecting command argument exceeding max length')
            return False
        if '\n' in s or '\r' in s:
            log.error('Rejecting command argument containing newline')
            return False
        if i > 0 and ';' in s:
            log.error('Rejecting command argument containing semicolon')
            return False
    arg = '[%d] ' % int(time.time()) + ';'.join(str(j) for j in args)
    arg_bytes = (arg + '\n').encode('utf-8')
    with CMD_LOCK:
        log.info('Sending command: %s' % arg)
        try:
            fd = os.open(CMDFILE, os.O_WRONLY)
            os.write(fd, arg_bytes)
            os.close(fd)
        except Exception as e:
            log.error(e)
            return False
        return True


def read_status(statusfile):
    '''Monitor the Nagios status file and update our global data store
    with the data as it changes.

    '''
    global NAGIOS
    mtime = None
    while True:
        if not os.path.isfile(statusfile):
            with STATE_LOCK:
                NAGIOS = Nagios(None)
            time.sleep(5)
            continue

        stat = os.stat(statusfile)
        if mtime is None or stat.st_mtime > mtime:
            try:
                new_state = Nagios(statusfile)
            except ValueError:
                log.error('Malformed status file (possibly the state '
                          'retention file). Check your arguments.')
                sys.exit(-1)
            with STATE_LOCK:
                NAGIOS = new_state
            mtime = stat.st_mtime
        time.sleep(1)


def read_log(logfile):
    '''This function reads the Nagios log file and parses events. This
    allows us to provide a pubsub style interface so people can get
    real-time updates from the Nagios system.

    '''
    global NLOG, NLOGLINES
    f = open(logfile, 'r', encoding='utf-8', errors='replace')
    cts = 0
    while True:
        loc = f.tell()
        line = f.readline()
        if not line:
            time.sleep(1)
            f.seek(loc)
            cts += 1  # Handle log rollovers by watching for no activity.
            if cts >= 60:
                f = open(logfile, 'r', encoding='utf-8', errors='replace')
                cts = 0
        else:
            with LOG_LOCK:
                NLOGLINES += 1
                NLOG.append(line.strip())
                NLOG = NLOG[-1000:]
    f.close()


def write_pid():
    '''Write pid file atomically using O_CREAT|O_EXCL to prevent races.

    '''
    try:
        fd = os.open(PID_FILE, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o644)
        os.write(fd, str(os.getpid()).encode('utf-8'))
        os.close(fd)
    except FileExistsError:
        sys.stderr.write("%s already exists, exiting\n" % PID_FILE)
        sys.exit(1)
    except Exception as e:
        sys.stderr.write("%s\n" % e)
        sys.stderr.write("Unable to write pid file: %s\n" % PID_FILE)
        sys.exit(1)


def main(argv):
    '''A simple REST API for Nagios3.

    '''
    global CMDFILE, CMD_ENABLED, LOG_ENABLED, ALLOW_ORIGIN, PID_FILE, CFG_DIRECTORY, API_KEYS, RATE_LIMITER

    parser = OptionParser(description='Give Nagios a REST API.')
    parser.add_option('-o', '--allow-origin', dest='alloworigin',
                      metavar='ORIGIN',
                      help='Access-Control-Allow-Origin header contents. Must be an '
                      'explicit origin URL (e.g., "https://monitoring.example.com").')
    parser.add_option('--allow-origin-unsafe-wildcard',
                      dest='allow_unsafe_wildcard', action='store_true', default=False,
                      help='Allow --allow-origin to be set to "*". This is insecure '
                      'and should only be used in development or isolated environments.')
    parser.add_option('-s', '--status-file', dest='statusfile', metavar='FILE',
                      default='/var/cache/nagios3/status.dat',
                      help='The file that contains the Nagios status.')
    parser.add_option('-c', '--command-file', dest='commandfile', metavar='FILE',
                      default='/var/lib/nagios3/rw/nagios.cmd',
                      help='The file to write Nagios commands to.')
    parser.add_option('-d', '--config-directory', dest='cfgdirectory',
                      metavar='PATH', default='/usr/local/nagios/etc/objects',
                      help='Storage location for update_host endpoint files')
    parser.add_option('-l', '--log-file', dest='logfile', metavar='FILE',
                      default='/var/log/nagios3/nagios.log',
                      help='The file Nagios writes log events to.')
    parser.add_option('-b', '--bind', dest='bind_addr', metavar='ADDR',
                      default='127.0.0.1',
                      help='The address to listen for requests on. '
                      'Defaults to 127.0.0.1 (localhost only). Use 0.0.0.0 to listen '
                      'on all interfaces.')
    parser.add_option('-p', '--port', dest='port', metavar='PORT', type='int',
                      default=6315, help='The port to listen for requests on.')
    parser.add_option('-f', '--pid-file', dest='pid_file', metavar='PID_FILE',
                      default=PID_FILE, help='File to write pid to')
    parser.add_option('-q', '--quiet', dest='quiet', action='store_true',
                      help='Quiet mode')
    parser.add_option('--dev', dest='dev', action='store_true', default=False,
                      help='Use Flask development server instead of waitress. '
                      'Not recommended for production.')
    parser.add_option('-k', '--api-key-file', dest='apikeyfile', metavar='FILE',
                      help='File containing API keys (one per line). '
                      'When provided, all requests must include a valid key via '
                      'X-API-Key header or api_key query parameter.')
    parser.add_option('--rate-limit', dest='rate_limit', type='float',
                      default=0, metavar='RPS',
                      help='Max requests per second per IP (0 = unlimited). Default: 0')
    parser.add_option('--rate-limit-burst', dest='rate_burst', type='int',
                      default=20, metavar='N',
                      help='Burst size for rate limiter. Default: 20')
    parser.add_option('--tls-cert', dest='tls_cert', metavar='FILE',
                      help='Path to TLS certificate file (PEM). Enables HTTPS.')
    parser.add_option('--tls-key', dest='tls_key', metavar='FILE',
                      help='Path to TLS private key file (PEM). Required with --tls-cert.')
    (options, args) = parser.parse_args(args=argv[1:])

    if options.apikeyfile is not None:
        API_KEYS = load_api_keys(options.apikeyfile)
        log.info('Loaded %d API key(s) from %s', len(API_KEYS), options.apikeyfile)

    if options.tls_cert and not options.tls_key:
        parser.error('--tls-key is required when using --tls-cert')
    if options.tls_key and not options.tls_cert:
        parser.error('--tls-cert is required when using --tls-key')
    if options.tls_cert and not os.path.isfile(options.tls_cert):
        parser.error('TLS certificate file not found: %s' % options.tls_cert)
    if options.tls_key and not os.path.isfile(options.tls_key):
        parser.error('TLS key file not found: %s' % options.tls_key)

    if not os.path.isfile(options.statusfile):
        parser.error('Status file not found: %s' % options.statusfile)
    if options.port < 0 or options.port > 65535:
        parser.error('Port must be in the range 1..65535.')

    if options.quiet:
        logging.basicConfig(level=logging.WARNING)
    else:
        logging.basicConfig(level=logging.INFO)

    if os.path.exists(options.commandfile):
        CMD_ENABLED = True
        CMDFILE = options.commandfile
    if options.alloworigin:
        if options.allow_unsafe_wildcard:
            ALLOW_ORIGIN = options.alloworigin
            if options.alloworigin == '*':
                log.warning('CORS wildcard origin enabled -- any website can '
                            'make cross-origin requests to this API')
        else:
            try:
                ALLOW_ORIGIN = validate_allow_origin(options.alloworigin)
            except ValueError as e:
                parser.error(str(e))

    CFG_DIRECTORY = options.cfgdirectory
    PID_FILE = options.pid_file
    write_pid()

    if CMD_ENABLED and API_KEYS is None:
        log.warning('Command file is enabled but no API key file is configured. '
                    'Write endpoints (update_host, raw_command, restart, downtime, '
                    'etc.) are accessible without authentication. '
                    'Use --api-key-file to require auth.')

    if API_KEYS and not options.tls_cert:
        log.warning('API key authentication is enabled but TLS is not. '
                    'API keys will be transmitted in cleartext. '
                    'Consider using --tls-cert/--tls-key or a TLS-terminating proxy.')

    if options.rate_limit > 0:
        RATE_LIMITER = RateLimiter(options.rate_limit, options.rate_burst)
        log.info('Rate limiting enabled: %.1f req/s per IP, burst %d',
                 options.rate_limit, options.rate_burst)

    flask_app = Flask(__name__)

    @flask_app.before_request
    def check_rate_limit():
        if RATE_LIMITER is None:
            return None
        client_ip = flask_request.remote_addr
        if not RATE_LIMITER.allow(client_ip):
            return Response(
                dumps({'success': False, 'content': 'Rate limit exceeded'}),
                status=429,
                content_type='application/json'
            )

    @flask_app.before_request
    def check_auth():
        if API_KEYS is None:
            return None
        key = (flask_request.headers.get('X-API-Key')
               or flask_request.args.get('api_key'))
        if not key or not _check_api_key(key):
            log.warning('Rejected unauthenticated request from %s',
                        flask_request.remote_addr)
            return Response(
                dumps({'success': False, 'content': 'Authentication required'}),
                status=401,
                content_type='application/json'
            )

    @flask_app.route('/', defaults={'path': ''}, methods=['GET', 'POST'])
    @flask_app.route('/<path:path>', methods=['GET', 'POST'])
    def catch_all(path):
        return http_handler(flask_request)

    status_thread = threading.Thread(
        target=_loop_forever, args=(read_status, options.statusfile),
        daemon=True)
    status_thread.start()

    if os.path.isfile(options.logfile):
        LOG_ENABLED = True
        log_thread = threading.Thread(
            target=_loop_forever, args=(read_log, options.logfile),
            daemon=True)
        log_thread.start()

    if RATE_LIMITER is not None:
        def _rate_cleanup():
            while True:
                time.sleep(300)
                RATE_LIMITER.cleanup()
        cleanup_thread = threading.Thread(target=_rate_cleanup, daemon=True)
        cleanup_thread.start()

    if options.bind_addr == '0.0.0.0':
        log.warning('Binding to 0.0.0.0 -- API is exposed on ALL network interfaces')

    log.info('Listening on %s:%d, starting to rock and roll!',
             options.bind_addr, options.port)
    if options.dev:
        log.warning('Running with Flask development server -- not for production use')
        ssl_ctx = None
        if options.tls_cert:
            ssl_ctx = (options.tls_cert, options.tls_key)
        flask_app.run(host=options.bind_addr, port=options.port,
                      ssl_context=ssl_ctx)
    else:
        if options.tls_cert:
            import ssl
            ssl_ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
            ssl_ctx.load_cert_chain(options.tls_cert, options.tls_key)
            from waitress import create_server
            server = create_server(flask_app, host=options.bind_addr,
                                   port=options.port, _quiet=options.quiet)
            server.socket = ssl_ctx.wrap_socket(
                server.socket, server_side=True)
            log.info('TLS enabled')
            server.run()
        else:
            serve(flask_app, host=options.bind_addr, port=options.port,
                  _quiet=options.quiet)
    return 1


def _loop_forever(func, *args):
    '''Run a function in a loop, restarting on exception (mimics diesel keep_alive).'''
    while True:
        try:
            func(*args)
        except SystemExit:
            raise
        except Exception:
            log.exception('Background loop %s crashed, restarting' % func.__name__)
            time.sleep(1)


def _exitfunc(*args):
    if PID_FILE is not None and os.path.isfile(PID_FILE):
        try:
            os.unlink(PID_FILE)
        except OSError:
            pass
    os._exit(0)


if __name__ == '__main__':
    pid = str(os.getpid())

    atexit.register(_exitfunc)
    signal(SIGTERM, _exitfunc)

    sys.exit(main(sys.argv))
